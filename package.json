{
  "name": "skill-loop",
  "version": "0.0.1",
  "description": "Loop AI agent skills across multiple tools",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "skill-loop": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "keywords": [
    "ai",
    "agent",
    "skills",
    "claude",
    "codex",
    "cursor",
    "sync",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.26.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "inquirer": "^12.6.0",
    "smol-toml": "^1.3.4"
  }
}
